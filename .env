# Verzija OpenCart-a koja se preuzima i gradi u image (docker/opencart/Dockerfile)
OPENCART_VERSION=4.1.0.3

# Portovi na hostu
HTTP_PORT=8083
ADMINER_PORT=8084

# Baza podataka (MariaDB)
DB_NAME=opencart
DB_USER=opencart
DB_PASSWORD=opencart
DB_ROOT_PASSWORD=opencart_root

# OpenCart admin nalog (kreira ga CLI installer pri prvom pokretanju)
OC_ADMIN_USER=admin
OC_ADMIN_PASSWORD=admin123
OC_ADMIN_EMAIL=admin@example.com
